# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง

# หาได้ที่ MongoDB Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/nps-store

# ตั้งเป็นข้อความสุ่มยาวๆ อะไรก็ได้ (ใช้เซ็น JWT) — อย่าเอาไปแชร์
JWT_SECRET=change-me-to-a-long-random-string

PORT=4000

# โดเมนของแอปฝั่งลูกค้า/แอดมิน คั่นด้วย comma (ใช้จำกัด CORS)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
